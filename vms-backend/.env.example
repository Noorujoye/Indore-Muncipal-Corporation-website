# Backend environment variables (example)

# Server
SERVER_PORT=8080

# Database
DB_URL=jdbc:postgresql://localhost:5432/imc_vms?stringtype=unspecified
DB_USERNAME=postgres
DB_PASSWORD=postgres

# CORS (comma-separated patterns)
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173

# JWT (REQUIRED in production)
JWT_SECRET=CHANGE_ME__USE_A_LONG_RANDOM_SECRET
JWT_ACCESS_TOKEN_EXP_MS=900000
JWT_REFRESH_TOKEN_EXP_MS=604800000

# Auth cookies (only used if you keep cookie mode)
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=Lax

# File upload
# FILE_UPLOAD_DIR=uploads

# Mail (set these to enable real email)
# Brevo SMTP (recommended)
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
# SMTP login (NOT necessarily the sender email)
MAIL_USERNAME=
# Brevo SMTP key
MAIL_PASSWORD=
# Sender address shown to recipients (must be a verified sender in Brevo)
MAIL_FROM=

# SMTP flags
# For Brevo: true/true
# For Gmail: true/true (but needs App Password)
# For local MailHog/smtp4dev: false/false (usually)
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true

# SMTP timeouts (ms)
MAIL_SMTP_CONNECTION_TIMEOUT_MS=5000
MAIL_SMTP_TIMEOUT_MS=5000
MAIL_SMTP_WRITE_TIMEOUT_MS=5000
